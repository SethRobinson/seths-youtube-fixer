{
  "manifest_version": 3,
  "name": "Seth's YouTube Fixer",
  "version": "0.1.0",
  "description": "Power-user controls for YouTube: Less like this, Don't recommend channel, forget recent activity, and comment search.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "unlimitedStorage", "tabs", "declarativeNetRequest"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://myactivity.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "syf_iframe",
        "enabled": false,
        "path": "rules/iframe-rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://myactivity.google.com/*"],
      "js": ["content/myactivity.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/embed.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Seth's YouTube Fixer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-ancestors 'self' https://www.youtube.com"
  },
  "web_accessible_resources": [
    {
      "resources": ["options/options.html", "options/options.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
